  u8g2.drawStr(3, 20, "Current temperature:");
  u8g2.drawStr(2, 30, "Target temperature:");

  u8g2.setFont(u8g2_font_6x10_tr);
  u8g2.drawStr(4, 45, "Start soldering:");

  u8g2.setFont(u8g2_font_6x12_tr);
  u8g2.drawStr(97, 31, targetStr);
  u8g2.drawStr(102, 21, tempStr);

  if (ready) {
    u8g2.drawXBM(101, 38, 11, 8, image_Layer_12_bits);
  } else {
    u8g2.drawXBM(101, 34, 10, 16, image_cross_small_bits);
  }

  u8g2.sendBuffer();
}

void setup() {
  pinMode(tempSensor, INPUT);
  pinMode(int1, INPUT_PULLUP);
  pinMode(int2, INPUT_PULLUP);
  pinMode(tempControl, OUTPUT);
  pinMode(LED1, OUTPUT);
  pinMode(LED2, OUTPUT);
  pinMode(A6, INPUT);
  attachInterrupt(digitalPinToInterrupt(int1), encoder, FALLING);
  u8g2.begin();
}

void loop() {
  temp = temp * 0.9 + analogRead(tempSensor) * 0.1;
  float currentTemp = map(temp, minADC, maxADC, minTemp, maxTemp);

  bool ready = (currentTemp >= target && target > minTemp);

  if (target <= minTemp) {
    analogWrite(tempControl, 0);
    digitalWrite(LED1, LOW);
    digitalWrite(LED2, LOW);
  } else if (currentTemp < target) {
    analogWrite(tempControl, 255);
    digitalWrite(LED1, HIGH);
    digitalWrite(LED2, LOW);
  } else {
    analogWrite(tempControl, 0);
    digitalWrite(LED1, LOW);
    digitalWrite(LED2, HIGH);
  }

  u8g2.clearBuffer();
  drawScreen(currentTemp, ready);
}